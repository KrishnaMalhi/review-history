// ─── DUPLICATE DETECTION ──────────────────────────────────

model DuplicateCandidate {
  id              String                   @id @default(uuid()) @db.Uuid
  entityAId       String                   @map("entity_a_id") @db.Uuid
  entityBId       String                   @map("entity_b_id") @db.Uuid
  similarityScore Decimal                  @map("similarity_score") @db.Decimal(5, 2)
  reasonCodesJson Json                     @map("reason_codes_json")
  status          DuplicateCandidateStatus @default(pending)
  createdAt       DateTime                 @default(now()) @map("created_at")
  resolvedAt      DateTime?                @map("resolved_at")

  // Relations
  entityA Entity               @relation("DuplicateEntityA", fields: [entityAId], references: [id])
  entityB Entity               @relation("DuplicateEntityB", fields: [entityBId], references: [id])
  votes   DuplicateMergeVote[]

  @@index([status, similarityScore(sort: Desc)])
  @@map("duplicate_candidates")
}

model DuplicateMergeVote {
  id                   String        @id @default(uuid()) @db.Uuid
  duplicateCandidateId String        @map("duplicate_candidate_id") @db.Uuid
  voterUserId          String        @map("voter_user_id") @db.Uuid
