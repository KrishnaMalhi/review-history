  bodyUr       String?  @map("body_ur") @db.Text
  isActive     Boolean  @default(true) @map("is_active")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([categoryKey, sentiment, isActive])
  @@map("response_templates")
}

// —— BLOGS ————————————————————————————————————————————————————————————————

model BlogPost {
  id          String   @id @default(uuid()) @db.Uuid
  authorUserId String  @map("author_user_id") @db.Uuid
  title       String   @db.VarChar(200)
  slug        String   @unique @db.VarChar(220)
  excerpt     String?  @db.VarChar(500)
  content     String   @db.Text
  coverImage  String?  @map("cover_image") @db.VarChar(500)
  isPublished Boolean  @default(false) @map("is_published")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  author User @relation(fields: [authorUserId], references: [id])

  @@index([isPublished, publishedAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("blog_posts")
}

// —— DISCUSSIONS ————————————————————————————————————————————————————————

model DiscussionPost {
  id           String   @id @default(uuid()) @db.Uuid
  authorUserId String   @map("author_user_id") @db.Uuid
  title        String?  @db.VarChar(200)
  body         String   @db.Text
  isAnonymous  Boolean  @default(false) @map("is_anonymous")
  status       String   @default("published") @db.VarChar(20)
  likeCount    Int      @default(0) @map("like_count")
  dislikeCount Int      @default(0) @map("dislike_count")
  commentCount Int      @default(0) @map("comment_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  author    User                 @relation(fields: [authorUserId], references: [id])
  comments  DiscussionComment[]
  reactions DiscussionReaction[]

  @@index([createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@map("discussion_posts")
}

model DiscussionComment {
  id           String   @id @default(uuid()) @db.Uuid
  discussionId String   @map("discussion_id") @db.Uuid
  authorUserId String   @map("author_user_id") @db.Uuid
  body         String   @db.VarChar(1000)
  isAnonymous  Boolean  @default(false) @map("is_anonymous")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  discussion DiscussionPost @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  author     User           @relation(fields: [authorUserId], references: [id])

  @@index([discussionId, createdAt(sort: Asc)])
  @@map("discussion_comments")
}

model DiscussionReaction {
  id           String                 @id @default(uuid()) @db.Uuid
  discussionId String                 @map("discussion_id") @db.Uuid
  userId       String                 @map("user_id") @db.Uuid
  type         DiscussionReactionType
  createdAt    DateTime               @default(now()) @map("created_at")

  discussion DiscussionPost @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id])

  @@unique([discussionId, userId])
  @@index([discussionId, type])
  @@map("discussion_reactions")
}
