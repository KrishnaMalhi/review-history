// ReviewHistory Platform - Full Database Schema
// 24 tables as defined in 04-database-schema.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────

enum UserStatus {
  active
  suspended
  banned
  deleted
}

enum UserTrustLevel {
  new_user
  established
  trusted
}

enum EntityStatus {
  draft
  active
  claimed
  under_review
  merged
  suspended
  archived
}

enum ReviewStatus {
  draft
  submitted
  published
  under_verification
  hidden
  removed
  archived
}

enum ModerationState {
  clean
  low_confidence
  under_verification
  hidden_pending_review
  removed_by_policy
}

enum RiskState {
  clean
  low_confidence
  under_verification
  hidden_pending_review
}

enum VoteType {
  helpful
  not_helpful
  seems_fake
}

enum ReportType {
  personal_information
  fake_review
  wrong_entity
  threatening_content
  spam
  harassment
  other
}

enum ReportStatus {
  open
  triaged
  resolved
  appealed
  closed
}

enum ClaimType {
  owner
  representative
  manager
}

enum ClaimVerificationMethod {
  phone_otp
  document
  business_email
}

enum ClaimStatus {
  pending
  approved
  rejected
  revoked
}

enum ModerationCaseSeverity {
  low
  medium
  high
  legal_sensitive
}

enum ModerationCaseStatus {
  open
  in_progress
  resolved
  appealed
  closed
}

enum ModerationActionType {
  keep
  label
  redact
  hide_review
  remove_review
  suspend_user
  ban_user
  merge_entity
  close_case
  escalate
}

enum DuplicateCandidateStatus {
  pending
  confirmed
  rejected
  merged
}

enum DuplicateVote {
  same_entity
  different_entity
}

enum NotificationChannel {
  in_app
  sms
  email
}

enum NotificationType {
  review_submitted
  review_flagged
  review_removed
  claim_approved
  claim_rejected
  reply_received
  entity_merged
  moderation_action
  trust_score_changed
}

enum AuditActorType {
  user
  admin
  system
}

enum ReplyStatus {
  published
  hidden
  removed
}

enum ReplyAuthorRole {
  claimed_owner
  admin
  moderator
}

enum BillingPlanStatus {
  active
  cancelled
  expired
  past_due
}

enum InvoiceStatus {
  pending
  paid
  failed
  refunded
}

enum AliasType {
  alternate_name
  former_name
  merged_from
  common_misspelling
}

enum AliasSource {
  user_submitted
  system_generated
  admin_created
  merge_result
}

// ─── USERS & IDENTITY ────────────────────────────────────

model User {
  id               String         @id @default(uuid()) @db.Uuid
  email            String?        @unique @db.VarChar(255)
  phoneE164        String         @unique @map("phone_e164") @db.VarChar(20)
  passwordHash     String?        @map("password_hash") @db.VarChar(255)
  phoneCountryCode String         @default("+92") @map("phone_country_code") @db.VarChar(5)
  isPhoneVerified  Boolean        @default(false) @map("is_phone_verified")
  isEmailVerified  Boolean        @default(false) @map("is_email_verified")
  displayName      String?        @map("display_name") @db.VarChar(100)
  usernameSlug     String?        @unique @map("username_slug") @db.VarChar(100)
  cityId           String?        @map("city_id") @db.Uuid
  trustLevel       UserTrustLevel @default(new_user) @map("trust_level")
  status           UserStatus     @default(active)
  role             String         @default("user") @db.VarChar(20)
  lastLoginAt      DateTime?      @map("last_login_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  deletedAt        DateTime?      @map("deleted_at")

  // Relations
  city             City?            @relation(fields: [cityId], references: [id])
  devices          UserDevice[]
  sessions         Session[]
  reviews          Review[]
  reviewVotes      ReviewVote[]
  reviewReports    ReviewReport[]
  reviewReplies    ReviewReply[]
  entityClaims     EntityClaim[]    @relation("ClaimRequester")
  approvedClaims   EntityClaim[]    @relation("ClaimApprover")
  claimedEntities  Entity[]         @relation("ClaimedEntity")
  createdEntities  Entity[]         @relation("CreatedEntity")
  notifications    Notification[]
  auditLogs        AuditLog[]
  billingCustomers BillingCustomer[]
  duplicateVotes   DuplicateMergeVote[]
  moderationCases  ModerationCase[]

  @@index([status])
  @@map("users")
}

model UserDevice {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @map("user_id") @db.Uuid
  deviceFingerprintHash String   @map("device_fingerprint_hash") @db.VarChar(64)
  firstIpHash           String   @map("first_ip_hash") @db.VarChar(64)
  lastIpHash            String   @map("last_ip_hash") @db.VarChar(64)
  userAgentHash         String   @map("user_agent_hash") @db.VarChar(64)
  firstSeenAt           DateTime @default(now()) @map("first_seen_at")
  lastSeenAt            DateTime @default(now()) @map("last_seen_at")
  riskScore             Int      @default(0) @map("risk_score")

  // Relations
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions Session[]

  @@index([userId])
  @@index([deviceFingerprintHash])
  @@map("user_devices")
}

model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash") @db.VarChar(64)
  deviceId         String?   @map("device_id") @db.Uuid
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  // Relations
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  device UserDevice? @relation(fields: [deviceId], references: [id])

  @@index([userId])
  @@index([refreshTokenHash])
  @@map("sessions")
}

// ─── CATEGORIES & LOCATIONS ──────────────────────────────

model Category {
  id          String  @id @default(uuid()) @db.Uuid
  key         String  @unique @db.VarChar(50)
  nameEn      String  @map("name_en") @db.VarChar(100)
  nameUr      String  @map("name_ur") @db.VarChar(200)
  icon        String  @default("Tag") @db.VarChar(50)
  description String  @default("") @db.VarChar(300)
  isActive    Boolean @default(true) @map("is_active")
  sortOrder   Int     @default(0) @map("sort_order")

  // Relations
  warningTags WarningTag[]
  entities    Entity[]

  @@index([isActive, sortOrder])
  @@map("categories")
}

model WarningTag {
  id             String  @id @default(uuid()) @db.Uuid
  categoryId     String  @map("category_id") @db.Uuid
  key            String  @unique @db.VarChar(50)
  labelEn        String  @map("label_en") @db.VarChar(100)
  labelUr        String  @map("label_ur") @db.VarChar(200)
  severityWeight Int     @default(1) @map("severity_weight")
  isActive       Boolean @default(true) @map("is_active")
  isPositive     Boolean @default(false) @map("is_positive")

  // Relations
  category       Category        @relation(fields: [categoryId], references: [id])
  reviewTagLinks ReviewTagLink[]

  @@index([categoryId, isActive])
  @@map("warning_tags")
}

model Country {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @db.VarChar(120)
  isoCode    String   @unique @map("iso_code") @db.VarChar(10)
  flag       String?  @db.VarChar(20)
  phoneCode  String?  @map("phone_code") @db.VarChar(30)
  currency   String?  @db.VarChar(20)
  flagImage  String?  @map("flag_image") @db.VarChar(500)
  latitude   Decimal? @db.Decimal(10, 7)
  longitude  Decimal? @db.Decimal(10, 7)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  states    State[]
  cities    City[]
  timezones Timezone[]

  @@index([isActive])
  @@map("countries")
}

model State {
  id          String   @id @default(uuid()) @db.Uuid
  countryId   String   @map("country_id") @db.Uuid
  name        String   @db.VarChar(120)
  isoCode     String   @map("iso_code") @db.VarChar(30)
  latitude    Decimal? @db.Decimal(10, 7)
  longitude   Decimal? @db.Decimal(10, 7)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  country Country @relation(fields: [countryId], references: [id], onDelete: Cascade)
  cities  City[]

  @@unique([countryId, isoCode])
  @@index([countryId, isActive])
  @@map("states")
}

model Timezone {
  id            String   @id @default(uuid()) @db.Uuid
  countryId     String   @map("country_id") @db.Uuid
  zoneName      String   @map("zone_name") @db.VarChar(120)
  gmtOffset     Int      @map("gmt_offset")
  gmtOffsetName String   @map("gmt_offset_name") @db.VarChar(20)
  abbreviation  String?  @db.VarChar(20)
  tzName        String?  @map("tz_name") @db.VarChar(120)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  country Country @relation(fields: [countryId], references: [id], onDelete: Cascade)
  cities  City[]

  @@unique([countryId, zoneName])
  @@index([countryId])
  @@map("timezones")
}

model City {
  id          String   @id @default(uuid()) @db.Uuid
  countryId   String?  @map("country_id") @db.Uuid
  stateId     String?  @map("state_id") @db.Uuid
  timezoneId  String?  @map("timezone_id") @db.Uuid
  externalKey String?  @unique @map("external_key") @db.VarChar(255)
  nameEn      String   @map("name_en") @db.VarChar(100)
  nameUr      String?  @map("name_ur") @db.VarChar(200)
  province    String?  @db.VarChar(100)
  latitude    Decimal? @db.Decimal(10, 7)
  longitude   Decimal? @db.Decimal(10, 7)
  isActive    Boolean  @default(true) @map("is_active")

  // Relations
  country    Country?   @relation(fields: [countryId], references: [id])
  state      State?     @relation(fields: [stateId], references: [id])
  timezone   Timezone?  @relation(fields: [timezoneId], references: [id])
  localities Locality[]
  entities   Entity[]
  users      User[]

  @@index([countryId, stateId, nameEn])
  @@index([timezoneId])
  @@index([isActive])
  @@map("cities")
}

model Locality {
  id         String  @id @default(uuid()) @db.Uuid
  cityId     String  @map("city_id") @db.Uuid
  nameEn     String  @map("name_en") @db.VarChar(100)
  nameUr     String  @map("name_ur") @db.VarChar(200)
  postalCode String? @map("postal_code") @db.VarChar(10)
  isActive   Boolean @default(true) @map("is_active")

  // Relations
  city     City     @relation(fields: [cityId], references: [id])
  entities Entity[]

  @@index([cityId, isActive])
  @@map("localities")
}

// ─── ENTITIES ─────────────────────────────────────────────

model Entity {
  id                    String       @id @default(uuid()) @db.Uuid
  categoryId            String       @map("category_id") @db.Uuid
  displayName           String       @map("display_name") @db.VarChar(200)
  normalizedName        String       @map("normalized_name") @db.VarChar(200)
  phoneE164             String?      @map("phone_e164") @db.VarChar(20)
  alternatePhonesJson   Json?        @map("alternate_phones_json")
  addressLine           String?      @map("address_line") @db.VarChar(300)
  landmark              String?      @db.VarChar(200)
  cityId                String       @map("city_id") @db.Uuid
  localityId            String?      @map("locality_id") @db.Uuid
  latitude              Decimal?     @db.Decimal(10, 7)
  longitude             Decimal?     @db.Decimal(10, 7)
  entityFingerprint     String       @map("entity_fingerprint") @db.VarChar(64)
  status                EntityStatus @default(active)
  isClaimed             Boolean      @default(false) @map("is_claimed")
  claimedUserId         String?      @map("claimed_user_id") @db.Uuid
  averageRating         Decimal      @default(0) @map("average_rating") @db.Decimal(3, 2)
  ratingCount           Int          @default(0) @map("rating_count")
  reviewCount           Int          @default(0) @map("review_count")
  trustScore            Int          @default(0) @map("trust_score")
  suspiciousReviewCount Int          @default(0) @map("suspicious_review_count")
  hiddenReviewCount     Int          @default(0) @map("hidden_review_count")
  lastReviewedAt        DateTime?    @map("last_reviewed_at")
  createdByUserId       String       @map("created_by_user_id") @db.Uuid
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")
  deletedAt             DateTime?    @map("deleted_at")

  // Relations
  category            Category             @relation(fields: [categoryId], references: [id])
  city                City                 @relation(fields: [cityId], references: [id])
  locality            Locality?            @relation(fields: [localityId], references: [id])
  claimedUser         User?                @relation("ClaimedEntity", fields: [claimedUserId], references: [id])
  createdByUser       User                 @relation("CreatedEntity", fields: [createdByUserId], references: [id])
  aliases             EntityAlias[]
  claims              EntityClaim[]
  reviews             Review[]
  trustScoreEvents    TrustScoreEvent[]
  duplicatesAsA       DuplicateCandidate[] @relation("DuplicateEntityA")
  duplicatesAsB       DuplicateCandidate[] @relation("DuplicateEntityB")

  @@index([normalizedName])
  @@index([entityFingerprint])
  @@index([cityId, localityId, categoryId])
  @@index([status])
  @@index([trustScore(sort: Desc)])
  @@index([averageRating(sort: Desc)])
  @@index([reviewCount(sort: Desc)])
  @@index([status, categoryId, cityId])
  @@index([createdAt(sort: Desc)])
  @@map("entities")
}

model EntityAlias {
  id        String      @id @default(uuid()) @db.Uuid
  entityId  String      @map("entity_id") @db.Uuid
  aliasText String      @map("alias_text") @db.VarChar(200)
  aliasType AliasType   @map("alias_type")
  source    AliasSource
  createdAt DateTime    @default(now()) @map("created_at")

  // Relations
  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@index([aliasText])
  @@map("entity_aliases")
}

model EntityClaim {
  id                    String                  @id @default(uuid()) @db.Uuid
  entityId              String                  @map("entity_id") @db.Uuid
  requesterUserId       String                  @map("requester_user_id") @db.Uuid
  claimType             ClaimType               @map("claim_type")
  verificationMethod    ClaimVerificationMethod  @map("verification_method")
  submittedPhone        String?                 @map("submitted_phone") @db.VarChar(20)
  submittedDocumentsJson Json?                  @map("submitted_documents_json")
  status                ClaimStatus             @default(pending)
  adminNotes            String?                 @map("admin_notes") @db.Text
  approvedBy            String?                 @map("approved_by") @db.Uuid
  approvedAt            DateTime?               @map("approved_at")
  createdAt             DateTime                @default(now()) @map("created_at")
  updatedAt             DateTime                @updatedAt @map("updated_at")

  // Relations
  entity    Entity @relation(fields: [entityId], references: [id])
  requester User   @relation("ClaimRequester", fields: [requesterUserId], references: [id])
  approver  User?  @relation("ClaimApprover", fields: [approvedBy], references: [id])

  @@index([entityId])
  @@index([requesterUserId])
  @@index([status])
  @@map("entity_claims")
}

// ─── REVIEWS ──────────────────────────────────────────────

model Review {
  id              String          @id @default(uuid()) @db.Uuid
  entityId        String          @map("entity_id") @db.Uuid
  authorUserId    String          @map("author_user_id") @db.Uuid
  overallRating   Int             @map("overall_rating") @db.SmallInt
  title           String?         @db.VarChar(200)
  body            String          @db.Text
  visitContext    String?         @map("visit_context") @db.VarChar(100)
  experienceMonth Int?            @map("experience_month") @db.SmallInt
  experienceYear  Int?            @map("experience_year") @db.SmallInt
  languageCode    String          @default("en") @map("language_code") @db.VarChar(5)
  status          ReviewStatus    @default(submitted)
  moderationState ModerationState @default(clean) @map("moderation_state")
  riskState       RiskState       @default(clean) @map("risk_state")
  helpfulCount    Int             @default(0) @map("helpful_count")
  notHelpfulCount Int             @default(0) @map("not_helpful_count")
  fakeVoteCount   Int             @default(0) @map("fake_vote_count")
  underVerification Boolean       @default(false) @map("under_verification")
  publishedAt     DateTime?       @map("published_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  deletedAt       DateTime?       @map("deleted_at")

  // Relations
  entity   Entity          @relation(fields: [entityId], references: [id])
  author   User            @relation(fields: [authorUserId], references: [id])
  tagLinks ReviewTagLink[]
  votes    ReviewVote[]
  reports  ReviewReport[]
  replies  ReviewReply[]

  @@unique([authorUserId, entityId], name: "one_review_per_entity")
  @@index([entityId, status, createdAt(sort: Desc)])
  @@index([authorUserId])
  @@index([status, moderationState])
  @@index([publishedAt(sort: Desc)])
  @@map("reviews")
}

model ReviewTagLink {
  id        String   @id @default(uuid()) @db.Uuid
  reviewId  String   @map("review_id") @db.Uuid
  tagId     String   @map("tag_id") @db.Uuid
  intensity Int?     @db.SmallInt
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  review Review     @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  tag    WarningTag @relation(fields: [tagId], references: [id])

  @@index([reviewId])
  @@index([tagId])
  @@map("review_tag_links")
}

model ReviewVote {
  id          String   @id @default(uuid()) @db.Uuid
  reviewId    String   @map("review_id") @db.Uuid
  voterUserId String   @map("voter_user_id") @db.Uuid
  voteType    VoteType @map("vote_type")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  voter  User   @relation(fields: [voterUserId], references: [id])

  @@unique([reviewId, voterUserId, voteType], name: "one_vote_per_type_per_user")
  @@index([reviewId])
  @@map("review_votes")
}

model ReviewReport {
  id             String       @id @default(uuid()) @db.Uuid
  reviewId       String       @map("review_id") @db.Uuid
  reporterUserId String?      @map("reporter_user_id") @db.Uuid
  reportType     ReportType   @map("report_type")
  reasonText     String?      @map("reason_text") @db.Text
  status         ReportStatus @default(open)
  createdAt      DateTime     @default(now()) @map("created_at")
  resolvedAt     DateTime?    @map("resolved_at")
  resolverUserId String?      @map("resolver_user_id") @db.Uuid

  // Relations
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reporter User?  @relation(fields: [reporterUserId], references: [id])

  @@index([reviewId])
  @@index([status])
  @@map("review_reports")
}

model ReviewReply {
  id           String          @id @default(uuid()) @db.Uuid
  reviewId     String          @map("review_id") @db.Uuid
  authorUserId String          @map("author_user_id") @db.Uuid
  authorRole   ReplyAuthorRole @map("author_role")
  body         String          @db.Text
  status       ReplyStatus     @default(published)
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  // Relations
  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorUserId], references: [id])

  @@index([reviewId])
  @@map("review_replies")
}

// ─── MODERATION ───────────────────────────────────────────

model ModerationCase {
  id              String                 @id @default(uuid()) @db.Uuid
  objectType      String                 @map("object_type") @db.VarChar(50)
  objectId        String                 @map("object_id") @db.Uuid
  triggerType     String                 @map("trigger_type") @db.VarChar(50)
  severity        ModerationCaseSeverity
  status          ModerationCaseStatus   @default(open)
  assignedAdminId String?                @map("assigned_admin_id") @db.Uuid
  openedAt        DateTime               @default(now()) @map("opened_at")
  closedAt        DateTime?              @map("closed_at")

  // Relations
  assignedAdmin User?              @relation(fields: [assignedAdminId], references: [id])
  actions       ModerationAction[]

  @@index([status, severity])
  @@index([objectType, objectId])
  @@map("moderation_cases")
}

model ModerationAction {
  id               String               @id @default(uuid()) @db.Uuid
  caseId           String               @map("case_id") @db.Uuid
  actionType       ModerationActionType @map("action_type")
  performedBy      String               @map("performed_by") @db.Uuid
  notes            String?              @db.Text
  previousStateJson Json?               @map("previous_state_json")
  newStateJson     Json?                @map("new_state_json")
  createdAt        DateTime             @default(now()) @map("created_at")

  // Relations
  case ModerationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@map("moderation_actions")
}

// ─── DUPLICATE DETECTION ──────────────────────────────────

model DuplicateCandidate {
  id              String                   @id @default(uuid()) @db.Uuid
  entityAId       String                   @map("entity_a_id") @db.Uuid
  entityBId       String                   @map("entity_b_id") @db.Uuid
  similarityScore Decimal                  @map("similarity_score") @db.Decimal(5, 2)
  reasonCodesJson Json                     @map("reason_codes_json")
  status          DuplicateCandidateStatus @default(pending)
  createdAt       DateTime                 @default(now()) @map("created_at")
  resolvedAt      DateTime?                @map("resolved_at")

  // Relations
  entityA Entity               @relation("DuplicateEntityA", fields: [entityAId], references: [id])
  entityB Entity               @relation("DuplicateEntityB", fields: [entityBId], references: [id])
  votes   DuplicateMergeVote[]

  @@index([status, similarityScore(sort: Desc)])
  @@map("duplicate_candidates")
}

model DuplicateMergeVote {
  id                   String        @id @default(uuid()) @db.Uuid
  duplicateCandidateId String        @map("duplicate_candidate_id") @db.Uuid
  voterUserId          String        @map("voter_user_id") @db.Uuid
  vote                 DuplicateVote
  createdAt            DateTime      @default(now()) @map("created_at")

  // Relations
  candidate DuplicateCandidate @relation(fields: [duplicateCandidateId], references: [id], onDelete: Cascade)
  voter     User               @relation(fields: [voterUserId], references: [id])

  @@unique([duplicateCandidateId, voterUserId])
  @@map("duplicate_merge_votes")
}

// ─── TRUST SCORE ─────────────────────────────────────────

model TrustScoreEvent {
  id               String   @id @default(uuid()) @db.Uuid
  entityId         String   @map("entity_id") @db.Uuid
  eventType        String   @map("event_type") @db.VarChar(50)
  weight           Decimal  @db.Decimal(5, 2)
  sourceObjectType String   @map("source_object_type") @db.VarChar(50)
  sourceObjectId   String   @map("source_object_id") @db.Uuid
  effectiveAt      DateTime @default(now()) @map("effective_at")
  expiresAt        DateTime? @map("expires_at")
  createdAt        DateTime @default(now()) @map("created_at")

  // Relations
  entity Entity @relation(fields: [entityId], references: [id])

  @@index([entityId, effectiveAt(sort: Desc)])
  @@map("trust_score_events")
}

// ─── AUDIT & NOTIFICATIONS ───────────────────────────────

model AuditLog {
  id           String         @id @default(uuid()) @db.Uuid
  actorUserId  String?        @map("actor_user_id") @db.Uuid
  actorType    AuditActorType @map("actor_type")
  action       String         @db.VarChar(100)
  objectType   String         @map("object_type") @db.VarChar(50)
  objectId     String         @map("object_id") @db.Uuid
  metadataJson Json?          @map("metadata_json")
  ipHash       String?        @map("ip_hash") @db.VarChar(64)
  createdAt    DateTime       @default(now()) @map("created_at")

  // Relations
  actor User? @relation(fields: [actorUserId], references: [id])

  @@index([objectType, objectId])
  @@index([actorUserId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

model Notification {
  id          String              @id @default(uuid()) @db.Uuid
  userId      String              @map("user_id") @db.Uuid
  channel     NotificationChannel @default(in_app)
  type        NotificationType
  payloadJson Json                @map("payload_json")
  readAt      DateTime?           @map("read_at")
  createdAt   DateTime            @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}

// ─── BILLING ─────────────────────────────────────────────

model BillingCustomer {
  id        String            @id @default(uuid()) @db.Uuid
  userId    String            @map("user_id") @db.Uuid
  planKey   String            @map("plan_key") @db.VarChar(50)
  status    BillingPlanStatus @default(active)
  startedAt DateTime          @default(now()) @map("started_at")
  endedAt   DateTime?         @map("ended_at")

  // Relations
  user     User             @relation(fields: [userId], references: [id])
  invoices BillingInvoice[]

  @@index([userId])
  @@map("billing_customers")
}

model BillingInvoice {
  id          String        @id @default(uuid()) @db.Uuid
  customerId  String        @map("customer_id") @db.Uuid
  amountPkr   Decimal       @map("amount_pkr") @db.Decimal(12, 2)
  currency    String        @default("PKR") @db.VarChar(5)
  status      InvoiceStatus @default(pending)
  externalRef String?       @map("external_ref") @db.VarChar(200)
  issuedAt    DateTime      @default(now()) @map("issued_at")
  paidAt      DateTime?     @map("paid_at")

  // Relations
  customer BillingCustomer @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@map("billing_invoices")
}
